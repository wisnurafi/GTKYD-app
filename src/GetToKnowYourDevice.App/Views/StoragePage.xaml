<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GetToKnowYourDevice.App.Views.StoragePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Padding="24">
        <TextBlock Text="No scan yet. Run a scan to view storage."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />

        <ScrollViewer Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Spacing="12">
                <TextBlock Text="Storage" Style="{StaticResource TitleTextBlockStyle}" />

                <Expander Header="Physical Disks" IsExpanded="True" HorizontalAlignment="Stretch">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Storage.PhysicalDisks, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold" />
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding MediaType}" /><Run Text=" / " />
                                        <Run Text="{Binding BusType}" /><Run Text=" / Health: " />
                                        <Run Text="{Binding HealthStatus}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <Expander Header="Volumes" IsExpanded="True" HorizontalAlignment="Stretch">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Storage.Volumes, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock>
                                        <Run Text="{Binding DriveLetter}" FontWeight="SemiBold" /><Run Text=" " />
                                        <Run Text="{Binding Label}" /><Run Text=" (" />
                                        <Run Text="{Binding FileSystem}" /><Run Text=")" />
                                    </TextBlock>
                                    <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Margin="0,2" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <Expander Header="Partitions" HorizontalAlignment="Stretch">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Storage.Partitions, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,2">
                                    <Run Text="Disk " /><Run Text="{Binding DiskNumber}" />
                                    <Run Text=" Part " /><Run Text="{Binding PartitionNumber}" />
                                    <Run Text=" " /><Run Text="{Binding Type}" />
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
