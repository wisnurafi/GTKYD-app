<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GetToKnowYourDevice.App.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="{x:Bind ViewModel.ApplicationName}" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock>
                <Run Text="Version " /><Run Text="{x:Bind ViewModel.ApplicationVersion}" />
                <Run Text=" (" /><Run Text="{x:Bind ViewModel.BuildConfiguration}" /><Run Text=")" />
            </TextBlock>
            <TextBlock Text="{x:Bind ViewModel.Description}" TextWrapping="Wrap" />

            <Border Style="{StaticResource SectionCard}">
                <StackPanel Spacing="4">
                    <TextBlock><Run Text=".NET:" FontWeight="SemiBold" /><Run Text="{x:Bind ViewModel.DotNetVersion}" /></TextBlock>
                    <TextBlock><Run Text="Windows App SDK:" FontWeight="SemiBold" /><Run Text="{x:Bind ViewModel.WindowsAppSdkVersion}" /></TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="License" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.LicenseInfo}" TextWrapping="Wrap" />
            <TextBlock Text="Third-party dependencies" FontWeight="SemiBold" />
            <TextBlock Text="{x:Bind ViewModel.ThirdPartyLicenses}" TextWrapping="Wrap" />

            <TextBlock Text="Privacy" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.PrivacyStatement}" TextWrapping="Wrap" />
            <TextBlock Text="{x:Bind ViewModel.LocalFirstStatement}" TextWrapping="Wrap" />

            <TextBlock Text="Repository" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.RepositoryPlaceholder}" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <Button Content="Copy System Summary" Click="CopySummary_Click" />
        </StackPanel>
    </ScrollViewer>
</Page>
