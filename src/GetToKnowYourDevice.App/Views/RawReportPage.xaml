<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GetToKnowYourDevice.App.Views.RawReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Raw Report" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Button Content="Export JSON" Click="ExportJson_Click" />
                <Button Content="Export CSV" Click="ExportCsv_Click" />
                <Button Content="Export PDF" Click="ExportPdf_Click" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                    Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <ComboBox x:Name="ViewCombo" SelectedIndex="0" SelectionChanged="ViewCombo_SelectionChanged">
                <ComboBoxItem Content="JSON" />
                <ComboBoxItem Content="Plain Text" />
                <ComboBoxItem Content="Diagnostics" />
            </ComboBox>
            <TextBox PlaceholderText="Search..." Width="240"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Copy All" Click="CopyAll_Click" />
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <TextBox Text="{x:Bind ViewModel.RenderedText, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap"
                     BorderThickness="0" Background="Transparent" />
        </ScrollViewer>

        <TextBlock Grid.Row="2" Text="No scan yet. Run a scan to view the report."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />
    </Grid>
</Page>
