<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GetToKnowYourDevice.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ToggleSwitch Header="Run Quick Scan on startup"
                          IsOn="{x:Bind ViewModel.Settings.RunQuickScanOnStartup, Mode=TwoWay}" />
            <ToggleSwitch Header="Automatically save completed scans"
                          IsOn="{x:Bind ViewModel.Settings.AutomaticallySaveCompletedScans, Mode=TwoWay}" />
            <NumberBox Header="Maximum history records" Minimum="1" Maximum="1000"
                       Value="{x:Bind ViewModel.Settings.MaximumHistoryRecords, Mode=TwoWay}" />
            <ToggleSwitch Header="Confirm before deleting"
                          IsOn="{x:Bind ViewModel.Settings.ConfirmBeforeDeleting, Mode=TwoWay}" />

            <TextBlock Text="Scan" Style="{StaticResource SubtitleTextBlockStyle}" />
            <NumberBox Header="Scan timeout (seconds)" Minimum="10" Maximum="3600"
                       Value="{x:Bind ViewModel.Settings.ScanTimeoutSeconds, Mode=TwoWay}" />
            <NumberBox Header="Per-scanner timeout (seconds)" Minimum="5" Maximum="600"
                       Value="{x:Bind ViewModel.Settings.PerScannerTimeoutSeconds, Mode=TwoWay}" />
            <NumberBox Header="Maximum parallel scanners" Minimum="1" Maximum="16"
                       Value="{x:Bind ViewModel.Settings.MaxParallelScanners, Mode=TwoWay}" />
            <ToggleSwitch Header="Include driver scan" IsOn="{x:Bind ViewModel.Settings.IncludeDriverScan, Mode=TwoWay}" />
            <ToggleSwitch Header="Include security scan" IsOn="{x:Bind ViewModel.Settings.IncludeSecurityScan, Mode=TwoWay}" />
            <ToggleSwitch Header="Include SMART data" IsOn="{x:Bind ViewModel.Settings.IncludeSmartData, Mode=TwoWay}" />
            <ToggleSwitch Header="Include peripheral scan" IsOn="{x:Bind ViewModel.Settings.IncludePeripheralScan, Mode=TwoWay}" />
            <ToggleSwitch Header="Request elevation when required"
                          IsOn="{x:Bind ViewModel.Settings.RequestElevationWhenRequired, Mode=TwoWay}" />

            <TextBlock Text="Privacy" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ToggleSwitch Header="Local-only mode" IsOn="{x:Bind ViewModel.Settings.LocalOnlyMode, Mode=TwoWay}" />
            <ToggleSwitch Header="Disable all external requests"
                          IsOn="{x:Bind ViewModel.Settings.DisableAllExternalRequests, Mode=TwoWay}" />
            <ToggleSwitch Header="Allow public IP lookup (off by default)"
                          IsOn="{x:Bind ViewModel.Settings.AllowPublicIpLookup, Mode=TwoWay}" />
            <ToggleSwitch Header="Allow connectivity test (off by default)"
                          IsOn="{x:Bind ViewModel.Settings.AllowConnectivityTest, Mode=TwoWay}" />
            <ToggleSwitch Header="Mask device identifiers in exports"
                          IsOn="{x:Bind ViewModel.Settings.MaskDeviceIdentifiers, Mode=TwoWay}" />

            <TextBlock Text="Export" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ToggleSwitch Header="Mask serial numbers" IsOn="{x:Bind ViewModel.Settings.MaskSerialNumbers, Mode=TwoWay}" />
            <ToggleSwitch Header="Mask username" IsOn="{x:Bind ViewModel.Settings.MaskUsername, Mode=TwoWay}" />
            <ToggleSwitch Header="Mask MAC address" IsOn="{x:Bind ViewModel.Settings.MaskMacAddress, Mode=TwoWay}" />
            <ToggleSwitch Header="Include full driver list" IsOn="{x:Bind ViewModel.Settings.IncludeFullDriverListInExport, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Save Settings" Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.SaveCommand}" />
                <TextBlock Text="{x:Bind ViewModel.SavedMessage, Mode=OneWay}" VerticalAlignment="Center"
                           Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
