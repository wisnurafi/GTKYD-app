<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GetToKnowYourDevice.App.Views.BatteryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Padding="24">
        <TextBlock Text="No scan yet. Run a scan to view battery."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />

        <Grid Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <!-- No battery (normal for desktops) -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        Visibility="{x:Bind ViewModel.HasBatteries, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                <FontIcon Glyph="&#xE83F;" FontSize="40" HorizontalAlignment="Center" />
                <TextBlock Text="No battery was detected on this device" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ScrollViewer Visibility="{x:Bind ViewModel.HasBatteries, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Battery" Style="{StaticResource TitleTextBlockStyle}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Batteries, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SectionCard}" Margin="0,4">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Chemistry:" /><Run Text="{Binding Chemistry}" />
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Health:" /><Run Text="{Binding HealthPercent}" /><Run Text="%" />
                                            <Run Text="  Wear:" /><Run Text="{Binding WearPercent}" /><Run Text="%" />
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Cycle Count:" /><Run Text="{Binding CycleCount}" />
                                            <Run Text="  Charge:" /><Run Text="{Binding ChargePercent}" /><Run Text="%" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
