<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GetToKnowYourDevice.App.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Padding="24">
        <TextBlock Text="No scan yet. Run a scan to view network."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />

        <ScrollViewer Visibility="{x:Bind ViewModel.HasReport, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Spacing="12">
                <TextBlock Text="Network" Style="{StaticResource TitleTextBlockStyle}" />

                <Expander Header="Overview" IsExpanded="True" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock><Run Text="Active Interface:" FontWeight="SemiBold" /><Run Text="{x:Bind ViewModel.Network.Summary.ActiveInterface, Mode=OneWay, Converter={StaticResource Unavailable}}" /></TextBlock>
                        <TextBlock><Run Text="Local IPv4:" FontWeight="SemiBold" /><Run Text="{x:Bind ViewModel.Network.Summary.LocalIPv4, Mode=OneWay, Converter={StaticResource Unavailable}}" /></TextBlock>
                        <TextBlock><Run Text="Default Gateway:" FontWeight="SemiBold" /><Run Text="{x:Bind ViewModel.Network.Summary.DefaultGateway, Mode=OneWay, Converter={StaticResource Unavailable}}" /></TextBlock>
                    </StackPanel>
                </Expander>

                <Expander Header="Adapters" IsExpanded="True" HorizontalAlignment="Stretch">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Network.Adapters, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding Description}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12">
                                        <Run Text="MAC:" /><Run Text="{Binding MacAddress}" />
                                        <Run Text="  Status:" /><Run Text="{Binding OperationalStatus}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <muxc:InfoBar xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                              IsOpen="True" IsClosable="False" Severity="Informational"
                              Title="External diagnostics"
                              Message="Connectivity tests and public IP lookup are off by default and require your consent in Settings." />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
